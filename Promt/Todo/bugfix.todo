## 🔴 HATA 3 — `sw.js:81` → `Failed to fetch` — Service Worker Vercel analytics'i engelliyor

**Kök neden:** Service worker, Vercel analytics script'ini (`/_vercel/insights/script.js`) önbellekten sunamıyor ve network isteği de başarısız olduğunda unhandled promise rejection oluşturuyor. Feature-09'daki `sw.js` içindeki fetch handler promise hataları yakalamıyor.

**Dosya:** `public/sw.js`

**Mevcut sorunlu bölüm (sw.js satır ~79-82):**
```js
// Statik assets — stale-while-revalidate
e.respondWith(
  caches.match(e.request).then(cached => {
    const fetchPromise = fetch(e.request).then(response => {  // <- satır 79
      if (response.ok) {
        caches.open(CACHE_NAME).then(cache => cache.put(e.request, response.clone()));
      }
      return response;
    });  // <- satır 81: .catch() YOK, burası patlıyor
    return cached || fetchPromise;
  })
);
```

### DÜZELTME 3A — `public/sw.js` dosyasını tamamen yeniden yaz

`public/sw.js` dosyasının **tüm içeriğini** şununla değiştir:

```js
// public/sw.js — KGED Service Worker v2
const CACHE_NAME = 'kged-v2';
const IMAGE_CACHE = 'kged-images-v1';

// Sadece kendi origin'imizin statik sayfalarını önbellekle
const PRECACHE_URLS = ['/', '/hakkimizda', '/galeri', '/iletisim', '/tuzuk'];

// Bu URL pattern'leri hiçbir zaman service worker'dan geçirme, direkt network'e git
const BYPASS_PATTERNS = [
  /\/_vercel\//,         // Vercel analytics, insights
  /vercel-insights/,
  /va\.vercel-scripts/,
  /supabase\.co/,        // Supabase API istekleri — SW'den geçirme
  /googleapis\.com/,
  /gstatic\.com/,
];

function shouldBypass(url) {
  return BYPASS_PATTERNS.some(pattern => pattern.test(url));
}

// Install: statik sayfaları önbellekle
self.addEventListener('install', (e) => {
  e.waitUntil(
    caches.open(CACHE_NAME)
      .then(cache => cache.addAll(PRECACHE_URLS))
      .catch(err => console.warn('[SW] Precache hatası (kritik değil):', err))
  );
  self.skipWaiting();
});

// Activate: eski cache'leri temizle
self.addEventListener('activate', (e) => {
  e.waitUntil(
    caches.keys().then(keys =>
      Promise.all(
        keys
          .filter(k => k !== CACHE_NAME && k !== IMAGE_CACHE)
          .map(k => caches.delete(k))
      )
    ).then(() => self.clients.claim())
  );
});

self.addEventListener('fetch', (e) => {
  const url = e.request.url;

  // 1. Bypass listesindeki URL'lere dokunma — direkt network
  if (shouldBypass(url)) return;

  // 2. POST, PUT, DELETE gibi mutation isteklerine dokunma
  if (e.request.method !== 'GET') return;

  // 3. chrome-extension:// veya diğer protocol'lar için dokunma
  if (!url.startsWith('http')) return;

  // 4. Supabase storage görselleri — cache-first (CDN görselleri)
  if (url.includes('.supabase.co/storage/v1/object/public/')) {
    e.respondWith(
      caches.open(IMAGE_CACHE).then(async cache => {
        const cached = await cache.match(e.request);
        if (cached) return cached;
        try {
          const response = await fetch(e.request);
          if (response.ok && response.status === 200) {
            cache.put(e.request, response.clone());
          }
          return response;
        } catch (err) {
          console.warn('[SW] Görsel fetch hatası:', err);
          // Görsel yoksa boş response dön — hata fırlatma
          return new Response('', { status: 503, statusText: 'Offline' });
        }
      })
    );
    return;
  }

  // 5. HTML sayfaları (navigate) — network-first, offline'da cache
  if (e.request.mode === 'navigate') {
    e.respondWith(
      fetch(e.request)
        .then(response => {
          // Başarılıysa cache'e de kaydet
          if (response.ok) {
            caches.open(CACHE_NAME).then(cache => cache.put(e.request, response.clone()));
          }
          return response;
        })
        .catch(() => {
          // Offline: cache'den dön
          return caches.match(e.request)
            .then(cached => cached || caches.match('/'))
            .then(r => r || new Response('<h1>Çevrimdışı</h1>', {
              headers: { 'Content-Type': 'text/html; charset=utf-8' }
            }));
        })
    );
    return;
  }

  // 6. CSS, JS, font gibi statik assets — stale-while-revalidate
  e.respondWith(
    caches.match(e.request).then(cached => {
      // Arka planda güncelle
      const networkFetch = fetch(e.request)
        .then(response => {
          if (response.ok && response.status === 200) {
            caches.open(CACHE_NAME)
              .then(cache => cache.put(e.request, response.clone()))
              .catch(() => {}); // Cache yazma hatası kritik değil
          }
          return response;
        })
        .catch(() => {
          // Network yoksa null dön, cached kullanılır
          return null;
        });

      // Cache varsa anında dön, yoksa network'ü bekle
      return cached || networkFetch.then(r => r || new Response('', { status: 503 }));
    })
  );
});
```

---

## 🔴 HATA 4 — Tüzük sayfasında PDF iframe → `X-Frame-Options: DENY` + CSP `frame-src` hatası

**Kök neden 1:** `vercel.json` içindeki `X-Frame-Options: DENY` header'ı tüm siteye uygulanıyor. Bu yüzden `tuzuk` sayfasındaki `<object>` veya `<iframe>` içinde kendi site URL'si (`kirged.org/tuzuk.pdf`) yüklenmeye çalışıldığında tarayıcı bunu engelliyor.

**Kök neden 2:** `vercel.json` CSP içinde `frame-src` yalnızca `https://www.google.com https://maps.google.com` izni veriyor. Kendi origin'imiz (`'self'`) frame-src'de izinli değil.

**Kök neden 3:** `site-renderer.js` içinde `renderConstitutionContent()` fonksiyonunda PDF embed şu şekilde yapılıyor:

```html
<object data="/tuzuk.pdf" type="application/pdf" ...>
```

Bu `<object>` aslında `X-Frame-Options` ile engellenmez (sadece iframe'ler engellenir), ama Chrome bazı durumlarda object tag'ini de engelleyebilir. Asıl sorun CSP'de `frame-src` yok ve PDF viewer için `object-src` da eksik.

### DÜZELTME 4A — `vercel.json` CSP ve frame-src düzeltmesi

**Dosya:** `vercel.json`

**Mevcut Content-Security-Policy value:**
```
"default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; frame-src https://www.google.com https://maps.google.com; connect-src 'self' https://maps.googleapis.com https://vitals.vercel-insights.com https://*.supabase.co"
```

**Yeni Content-Security-Policy value (tüm satırı şununla değiştir):**
```
"default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://va.vercel-scripts.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; frame-src 'self' https://www.google.com https://maps.google.com; object-src 'self'; connect-src 'self' https://maps.googleapis.com https://vitals.vercel-insights.com https://va.vercel-scripts.com https://*.supabase.co wss://*.supabase.co; worker-src 'self'"
```

Değişiklikler:
- `frame-src` başına `'self'` eklendi → kendi PDF'leri iframe/object içinde gösterilebilir
- `object-src 'self'` eklendi → `<object>` tag'i için
- `connect-src`'e `wss://*.supabase.co` ve `https://va.vercel-scripts.com` eklendi
- `worker-src 'self'` eklendi → service worker için
- `img-src`'e `blob:` eklendi → canvas/blob URL'ler için

### DÜZELTME 4B — `vercel.json` X-Frame-Options düzeltmesi

**Dosya:** `vercel.json`

**Mevcut:**
```json
{ "key": "X-Frame-Options", "value": "DENY" }
```

**Yeni:**
```json
{ "key": "X-Frame-Options", "value": "SAMEORIGIN" }
```

`DENY` → `SAMEORIGIN` olarak değiştirildi. Bu sayede kendi origin'imizden (`kirged.org`) gelen iframe/object istekleri çalışır, dış sitelerden embed hala engellenir.

### DÜZELTME 4C — Tüzük PDF viewer kullanıcı onayı ekle (UX iyileştirmesi)

**Dosya:** `src/build/site-renderer.js`

**Fonksiyon:** `renderConstitutionContent()`

**Mevcut `pdfViewer` değişkeni:**
```js
const pdfViewer = hasConstitution
  ? `<div style="border:1px solid ...">
      <div style="background:var(--color-primary-950)...">Tüzük Belgesi Görüntüleyici</div>
      <object data="${escapeAttr(content.constitution.pdfPath)}" type="application/pdf" ...>
```

**Yeni `pdfViewer` değişkeni** — iframe yerine güvenli link + embed:
```js
const pdfViewer = hasConstitution
  ? `<div style="border:1px solid var(--color-border);border-radius:var(--radius-xl);overflow:hidden;margin-bottom:var(--space-8);background:var(--color-surface);box-shadow:var(--shadow-sm);">
      <div style="background:var(--color-primary-950);padding:var(--space-3) var(--space-5);display:flex;align-items:center;justify-content:space-between;gap:var(--space-2);">
        <span style="font-size:var(--text-sm);color:var(--color-primary-100);font-weight:600;display:flex;align-items:center;gap:0.5rem;">
          <svg style="width:18px;height:18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Tüzük Belgesi Görüntüleyici
        </span>
        <a href="${escapeAttr(content.constitution.pdfPath)}" target="_blank" rel="noopener" style="font-size:var(--text-xs);color:var(--color-primary-300);text-decoration:none;">Yeni sekmede aç ↗</a>
      </div>
      <div id="pdf-cover" style="width:100%;min-height:400px;background:var(--color-surface);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;padding:2rem;text-align:center;">
        <svg style="width:48px;height:48px;color:var(--color-text-faint);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        <p style="color:var(--color-text-muted);font-size:var(--text-sm);max-width:280px;">PDF görüntüleyiciyi yüklemek için tıklayın (yalnızca tarayıcınız destekliyorsa gösterilir)</p>
        <button onclick="document.getElementById('pdf-cover').style.display='none';document.getElementById('pdf-iframe').style.display='block';"
          class="btn btn--primary">
          PDF'yi Görüntüle
        </button>
        <a href="${escapeAttr(content.constitution.pdfPath)}" download class="btn btn--secondary" style="margin-top:0.5rem;">
          İndir (PDF)
        </a>
      </div>
      <iframe id="pdf-iframe"
        src="${escapeAttr(content.constitution.pdfPath)}#toolbar=1&navpanes=0&scrollbar=1"
        title="Tüzük Belgesi"
        style="width:100%;min-height:600px;border:0;display:none;"
        loading="lazy">
        <p>PDF görüntüleyiciniz bu dosyayı gösteremiyor.
           <a href="${escapeAttr(content.constitution.pdfPath)}">İndir</a>
        </p>
      </iframe>
    </div>`
  : '';
```

